#!/bin/bash

# autobox - Run Claude Code in a safe container without git access
# Usage: autobox [options] [project-directory] [-- claude-args...]

set -euo pipefail

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

# Parse arguments
FULL_COPY=false
FORCE_REBUILD=false
USE_FIREWALL=false
USE_DOCKER=true
PURGE_SESSIONS=false
DOCKER_NETWORK=""
PROJECT_DIR=""
CLAUDE_ARGS=()

# State variables touched by the EXIT trap. Initialised up front so cleanup
# is safe under `set -u` even if the script exits before they are populated.
WORKTREE_DIR=""
BRANCH_NAME=""
ISOLATED_CLAUDE=""
HOST_PROJECT_NAME=""
CONTAINER_PROJECT_NAME="-workspace"
CONTAINER_ID=""
CONTAINER_EXIT_CODE=0
CONTINUE_ON_HOST=true
SESSIONS_SYNCED=false
GITFILE_BACKUP=""

while [[ $# -gt 0 ]]; do
    case $1 in
        --full)
            FULL_COPY=true
            shift
            ;;
        --rebuild)
            FORCE_REBUILD=true
            shift
            ;;
        --firewall)
            USE_FIREWALL=true
            shift
            ;;
        --no-firewall)
            USE_FIREWALL=false
            shift
            ;;
        --docker)
            USE_DOCKER=true
            shift
            ;;
        --no-docker)
            USE_DOCKER=false
            shift
            ;;
        --network)
            DOCKER_NETWORK="$2"
            shift 2
            ;;
        --purge-sessions)
            PURGE_SESSIONS=true
            shift
            ;;
        --continue)
            CONTINUE_ON_HOST=true
            shift
            ;;
        --no-continue)
            CONTINUE_ON_HOST=false
            shift
            ;;
        -h|--help)
            echo "autobox - Run Claude Code in a safe container without git access"
            echo "Usage: autobox [options] [project-directory] [-- claude-args...]"
            echo ""
            echo "Options:"
            echo "  --full             Include node_modules/.venv in the worktree"
            echo "  --rebuild          Force Docker image rebuild"
            echo "  --firewall         Restrict network to Anthropic API, GitHub, and npm"
            echo "  --no-firewall      (default) Unrestricted network access"
            echo "  --docker           (default) Mount Docker socket (lets Claude spin up sibling containers)"
            echo "  --no-docker        Don't mount Docker socket"
            echo "  --network NAME     Connect container to a Docker network (e.g. for databases)"
            echo "  --purge-sessions   Delete all session data for the given project and exit"
            echo "  --continue         (default) After exit, resume session on host (normal permissions)"
            echo "  --no-continue      Exit after container stops instead of resuming"
            echo "  -h, --help         Show help"
            echo ""
            echo "Arguments after -- are passed directly to Claude:"
            echo "  autobox /path/to/project -- --model opus --resume"
            echo ""
            echo "Creates a git worktree on a new branch, mounts it into a Docker"
            echo "container with .git hidden. Changes are written directly to disk."
            echo "No sync needed — review the branch when done."
            exit 0
            ;;
        --)
            shift
            CLAUDE_ARGS=("$@")
            break
            ;;
        *)
            PROJECT_DIR="$1"
            shift
            ;;
    esac
done

# Configuration
PROJECT_DIR="${PROJECT_DIR:-.}"
PROJECT_DIR="$(cd "$PROJECT_DIR" && pwd)"

# Handle --purge-sessions
if [ "$PURGE_SESSIONS" = true ]; then
    HOST_PROJECT_NAME=$(echo "$PROJECT_DIR" | sed 's|/|-|g')
    SESSION_DIR="$HOME/.claude/projects/$HOST_PROJECT_NAME"
    if [ -d "$SESSION_DIR" ]; then
        rm -rf "$SESSION_DIR"
        echo -e "${GREEN}✓ Purged session data for $PROJECT_DIR${NC}"
    else
        echo -e "${YELLOW}No session data found for $PROJECT_DIR${NC}"
    fi
    exit 0
fi

CONTAINER_IMAGE="autobox-dev"

# Resolve devcontainer directory: prefer repo-local, fall back to ~/.claude/devcontainer
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -f "$SCRIPT_DIR/devcontainer/Dockerfile" ]; then
    DEVCONTAINER_DIR="$SCRIPT_DIR/devcontainer"
elif [ -f "$HOME/.claude/devcontainer/Dockerfile" ]; then
    DEVCONTAINER_DIR="$HOME/.claude/devcontainer"
else
    DEVCONTAINER_DIR=""
fi

# Validate project directory
if [ ! -d "$PROJECT_DIR" ]; then
    echo -e "${RED}Error: Directory '$PROJECT_DIR' does not exist${NC}"
    exit 1
fi

# Validate project is a git repo
if [ ! -d "$PROJECT_DIR/.git" ] && [ ! -f "$PROJECT_DIR/.git" ]; then
    echo -e "${RED}Error: '$PROJECT_DIR' is not a git repository${NC}"
    exit 1
fi

# Generate unique IDs
CONTAINER_ID="$$-$(date +%s)"
BRANCH_NAME="agent/autobox-$(date +%Y%m%d-%H%M%S)"
WORKTREE_DIR="/tmp/autobox-$$-$(date +%s)"
ISOLATED_CLAUDE="/tmp/autobox-claude-$$"

sync_sessions_to_host() {
    if [ "$SESSIONS_SYNCED" = true ]; then return; fi
    SESSIONS_SYNCED=true

    if [ -n "$ISOLATED_CLAUDE" ] && [ -d "$ISOLATED_CLAUDE" ] && [ -n "$HOST_PROJECT_NAME" ]; then
        if [ -d "$ISOLATED_CLAUDE/projects/$CONTAINER_PROJECT_NAME" ] && [ "$(ls -A "$ISOLATED_CLAUDE/projects/$CONTAINER_PROJECT_NAME" 2>/dev/null)" ]; then
            echo -e "${YELLOW}Saving project sessions...${NC}"
            mkdir -p "$HOME/.claude/projects/$HOST_PROJECT_NAME"
            cp -a "$ISOLATED_CLAUDE/projects/$CONTAINER_PROJECT_NAME"/. "$HOME/.claude/projects/$HOST_PROJECT_NAME/" 2>/dev/null || true
            # Rewrite cwd to worktree path for --continue, or project dir if worktree is gone
            local resume_dir="${WORKTREE_DIR:-$PROJECT_DIR}"
            if [ ! -d "$resume_dir" ]; then resume_dir="$PROJECT_DIR"; fi
            find "$HOME/.claude/projects/$HOST_PROJECT_NAME" -name "*.jsonl" 2>/dev/null | while read -r f; do
                sed 's|"cwd": "/workspace"|"cwd": "'"$resume_dir"'"|g' "$f" > "$f.tmp" && mv "$f.tmp" "$f"
            done
        fi
        if [ -d "$ISOLATED_CLAUDE/sessions" ] && [ "$(ls -A "$ISOLATED_CLAUDE/sessions" 2>/dev/null)" ]; then
            echo -e "${YELLOW}Saving sessions...${NC}"
            mkdir -p "$HOME/.claude/sessions"
            cp -a "$ISOLATED_CLAUDE/sessions"/. "$HOME/.claude/sessions/" 2>/dev/null || true
        fi
        if [ -d "$ISOLATED_CLAUDE/todos" ] && [ "$(ls -A "$ISOLATED_CLAUDE/todos" 2>/dev/null)" ]; then
            echo -e "${YELLOW}Saving todos...${NC}"
            mkdir -p "$HOME/.claude/todos"
            cp -a "$ISOLATED_CLAUDE/todos"/. "$HOME/.claude/todos/" 2>/dev/null || true
        fi
    fi
}

restore_gitfile() {
    if [ -f "${GITFILE_BACKUP:-}" ] && [ -n "${WORKTREE_DIR:-}" ] && [ -d "$WORKTREE_DIR" ]; then
        rm -rf "$WORKTREE_DIR/.git"
        cp "$GITFILE_BACKUP" "$WORKTREE_DIR/.git"
        rm -f "$GITFILE_BACKUP"
    fi
}

enter_worktree() {
    local resume_dir="${WORKTREE_DIR:-$PROJECT_DIR}"
    if [ ! -d "$resume_dir" ]; then return; fi

    sync_sessions_to_host
    restore_gitfile
    rm -rf "$ISOLATED_CLAUDE" 2>/dev/null || true
    trap - SIGINT SIGTERM EXIT

    cd "$resume_dir"
    if [ "$CONTINUE_ON_HOST" = true ]; then
        echo
        echo -e "${GREEN}Resuming session in worktree (with normal permissions)...${NC}"
        claude --resume || true
    fi
    exec "$SHELL"
}

# Cleanup function for proper signal handling
cleanup() {
    local exit_code=$?

    # Disarm so SIGINT followed by EXIT doesn't run cleanup twice
    trap - SIGINT SIGTERM EXIT

    # If container is still running, stop it
    if [ -n "$CONTAINER_ID" ]; then
        local cid
        cid=$(docker ps -q --filter "name=autobox-${CONTAINER_ID}" 2>/dev/null || true)
        if [ -n "$cid" ]; then
            echo -e "\n${YELLOW}Stopping container...${NC}"
            docker stop "autobox-${CONTAINER_ID}" >/dev/null 2>&1 || true
        fi
    fi

    sync_sessions_to_host

    # Clean up isolated claude config
    if [ -n "${ISOLATED_CLAUDE:-}" ] && [ -d "$ISOLATED_CLAUDE" ]; then
        rm -rf "$ISOLATED_CLAUDE" 2>/dev/null || true
    fi

    restore_gitfile

    # Handle worktree: keep if changes exist, remove if clean
    if [ -n "${WORKTREE_DIR:-}" ] && [ -d "$WORKTREE_DIR" ]; then
        local changes
        changes=$(git -C "$WORKTREE_DIR" status --porcelain 2>/dev/null || true)
        if [ -z "$changes" ]; then
            git -C "$PROJECT_DIR" worktree remove "$WORKTREE_DIR" 2>/dev/null || true
            git -C "$PROJECT_DIR" branch -d "$BRANCH_NAME" 2>/dev/null || true
        else
            echo -e "${YELLOW}Worktree with changes preserved at: $WORKTREE_DIR${NC}"
            echo -e "${YELLOW}Branch: $BRANCH_NAME${NC}"
            echo -e "${YELLOW}To clean up: git -C '$PROJECT_DIR' worktree remove '$WORKTREE_DIR'${NC}"
        fi
    fi

    exit $exit_code
}

# Set up signal handlers
trap cleanup SIGINT SIGTERM EXIT

echo -e "${GREEN}=== autobox ===${NC}"
echo -e "Project: $PROJECT_DIR"
echo -e "Worktree: $WORKTREE_DIR"
echo -e "Branch: $BRANCH_NAME"
echo

# Create worktree
echo -e "${YELLOW}Creating worktree...${NC}"
git -C "$PROJECT_DIR" worktree add -b "$BRANCH_NAME" "$WORKTREE_DIR"
echo -e "${GREEN}✓ Worktree created on branch $BRANCH_NAME${NC}"

# Replace .git file with empty directory so Docker can mount tmpfs over it
# (worktree .git is a file pointing to the main repo — tmpfs needs a directory)
GITFILE_BACKUP="/tmp/autobox-gitfile-$$"
cp "$WORKTREE_DIR/.git" "$GITFILE_BACKUP"
rm "$WORKTREE_DIR/.git"
mkdir "$WORKTREE_DIR/.git"

# Copy dependency dirs if --full (not tracked by git, so not in worktree)
if [ "$FULL_COPY" = true ]; then
    for dir in node_modules .venv; do
        if [ -d "$PROJECT_DIR/$dir" ]; then
            echo -e "${YELLOW}Copying $dir...${NC}"
            cp -a "$PROJECT_DIR/$dir" "$WORKTREE_DIR/$dir"
        fi
    done
fi

# Create isolated .claude directory
mkdir -p "$ISOLATED_CLAUDE"

# Copy necessary config files into isolated directory
for file in .credentials.json settings.json CLAUDE.md; do
    if [ -f "$HOME/.claude/$file" ]; then
        cp "$HOME/.claude/$file" "$ISOLATED_CLAUDE/"
    fi
done
for script in "$HOME/.claude/"*.sh; do
    [ -f "$script" ] && cp "$script" "$ISOLATED_CLAUDE/"
done
for dir in devcontainer hooks agents skills plugins statsig; do
    if [ -d "$HOME/.claude/$dir" ]; then
        cp -a "$HOME/.claude/$dir" "$ISOLATED_CLAUDE/"
    fi
done

# Project name mapping:
# Host uses the real path (e.g. -home-lars-code-myproject)
# Container sees /workspace, so Claude stores sessions under -workspace
HOST_PROJECT_NAME=$(echo "$PROJECT_DIR" | sed 's|/|-|g')
CONTAINER_PROJECT_NAME="-workspace"

mkdir -p "$ISOLATED_CLAUDE/projects/$CONTAINER_PROJECT_NAME"
mkdir -p "$ISOLATED_CLAUDE/todos"
mkdir -p "$ISOLATED_CLAUDE/shell-snapshots"
mkdir -p "$ISOLATED_CLAUDE/sessions"

# Copy existing project sessions into the container's expected path
if [ -d "$HOME/.claude/projects/$HOST_PROJECT_NAME" ] && [ "$(ls -A "$HOME/.claude/projects/$HOST_PROJECT_NAME" 2>/dev/null)" ]; then
    echo -e "${YELLOW}Loading existing project sessions...${NC}"
    cp -a "$HOME/.claude/projects/$HOST_PROJECT_NAME"/. "$ISOLATED_CLAUDE/projects/$CONTAINER_PROJECT_NAME/"
    # Rewrite any cwd to /workspace so --resume works inside container
    find "$ISOLATED_CLAUDE/projects/$CONTAINER_PROJECT_NAME" -name "*.jsonl" 2>/dev/null | while read -r f; do
        sed 's|"cwd": "[^"]*"|"cwd": "/workspace"|g' "$f" > "$f.tmp" && mv "$f.tmp" "$f"
    done
else
    echo -e "${YELLOW}No existing sessions found for this project${NC}"
fi

# Copy existing sessions if they exist
if [ -d "$HOME/.claude/sessions" ] && [ "$(ls -A "$HOME/.claude/sessions" 2>/dev/null)" ]; then
    cp -a "$HOME/.claude/sessions"/. "$ISOLATED_CLAUDE/sessions/"
fi

# Copy existing todos if they exist
if [ -d "$HOME/.claude/todos" ] && [ "$(ls -A "$HOME/.claude/todos" 2>/dev/null)" ]; then
    cp -a "$HOME/.claude/todos"/. "$ISOLATED_CLAUDE/todos/"
fi

echo -e "${GREEN}✓ Isolated Claude configuration ready${NC}"

# Detect host Claude version (required for building the image)
# `awk` is used instead of `grep -oP` because BSD grep on macOS doesn't support -P.
HOST_CLAUDE_VERSION=$(claude --version 2>/dev/null \
    | awk 'match($0, /[0-9]+\.[0-9]+\.[0-9]+/) {print substr($0, RSTART, RLENGTH); exit}')
if [ -z "$HOST_CLAUDE_VERSION" ]; then
    echo -e "${RED}Error: Could not detect host Claude version. Is 'claude' on your PATH?${NC}"
    exit 1
fi

# Check if container image needs building/rebuilding
NEEDS_BUILD=false
if ! docker image inspect "$CONTAINER_IMAGE" >/dev/null 2>&1; then
    NEEDS_BUILD=true
elif [ "$FORCE_REBUILD" = true ]; then
    echo -e "${YELLOW}Forced rebuild requested${NC}"
    NEEDS_BUILD=true
else
    CURRENT_IMAGE_VERSION=$(docker image inspect "$CONTAINER_IMAGE" --format '{{index .Config.Labels "claude.version"}}' 2>/dev/null || echo "")
    if [ "$CURRENT_IMAGE_VERSION" != "$HOST_CLAUDE_VERSION" ]; then
        echo -e "${YELLOW}Claude version mismatch: image=$CURRENT_IMAGE_VERSION host=$HOST_CLAUDE_VERSION${NC}"
        NEEDS_BUILD=true
    fi
fi

if [ "$NEEDS_BUILD" = true ]; then
    if [ -n "$DEVCONTAINER_DIR" ]; then
        echo -e "${YELLOW}Building container${HOST_CLAUDE_VERSION:+ (v$HOST_CLAUDE_VERSION)}...${NC}"
        BUILD_ARGS=(--build-arg "CLAUDE_CODE_VERSION=$HOST_CLAUDE_VERSION")
        if [ "$FORCE_REBUILD" = true ]; then
            BUILD_ARGS+=(--no-cache)
        fi
        docker build -t "$CONTAINER_IMAGE" "${BUILD_ARGS[@]}" "$DEVCONTAINER_DIR/"
    else
        echo -e "${RED}Error: Cannot find Dockerfile. Run from the autobox repo or place Dockerfile at ~/.claude/devcontainer/Dockerfile${NC}"
        exit 1
    fi
fi

# Resolve Docker socket mount before printing status
DOCKER_SOCK="/var/run/docker.sock"
if [ "$USE_DOCKER" = true ]; then
    if [ ! -S "$DOCKER_SOCK" ]; then
        echo -e "${YELLOW}Warning: Docker socket not found at $DOCKER_SOCK — disabling Docker mount${NC}"
        USE_DOCKER=false
    else
        if stat --version >/dev/null 2>&1; then
            DOCKER_GID=$(stat -c '%g' "$DOCKER_SOCK")
        else
            DOCKER_GID=$(stat -f '%g' "$DOCKER_SOCK")
        fi
    fi
fi

# Run container
echo -e "${GREEN}Starting container...${NC}"
echo -e "${YELLOW}You're now in a safe environment. .git is not accessible.${NC}"
echo -e "${GREEN}Claude will auto-start with --dangerously-skip-permissions${NC}"
if [ "$USE_FIREWALL" = true ]; then
    echo -e "${GREEN}Network firewall enabled (only Anthropic, GitHub, npm allowed)${NC}"
else
    echo -e "${YELLOW}Network: unrestricted (pass --firewall to restrict)${NC}"
fi
if [ "$USE_DOCKER" = true ]; then
    echo -e "${GREEN}Docker socket mounted (Claude can manage sibling containers)${NC}"
    if [ "$USE_FIREWALL" = true ]; then
        echo -e "${YELLOW}Note: Firewall applies to this container only, not to containers Claude spawns${NC}"
    fi
fi
echo

# Build docker run arguments
DOCKER_ARGS=(
    -it --rm
    --name "autobox-${CONTAINER_ID}"
    -v "$WORKTREE_DIR:/workspace"
    --tmpfs /workspace/.git:rw,exec,uid=1000,gid=1000
    -v "$ISOLATED_CLAUDE:/home/node/.claude"
    --tmpfs /tmp:rw,exec,size=100m
    --sysctl net.ipv6.conf.all.disable_ipv6=1
    -e TZ="${TZ:-$(cat /etc/timezone 2>/dev/null || echo UTC)}"
    -w /workspace
)

# Pass through PipeWire socket for audio notifications (hook sounds)
PIPEWIRE_SOCK="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/pipewire-0"
if [ -S "$PIPEWIRE_SOCK" ]; then
    DOCKER_ARGS+=(
        -v "$PIPEWIRE_SOCK:/run/user/1000/pipewire-0"
        -e XDG_RUNTIME_DIR=/run/user/1000
    )
fi

if [ -f "$HOME/.claude.json" ]; then
    DOCKER_ARGS+=(-v "$HOME/.claude.json:/home/node/.claude.json")
fi

if [ -n "$DOCKER_NETWORK" ]; then
    DOCKER_ARGS+=(--network "$DOCKER_NETWORK")
fi

if [ "$USE_DOCKER" = true ]; then
    DOCKER_ARGS+=(-v "$DOCKER_SOCK:/var/run/docker.sock" --group-add "$DOCKER_GID")
fi

# Always use entrypoint (handles firewall + throwaway git init)
DOCKER_ARGS+=(--entrypoint /usr/local/bin/entrypoint.sh)
if [ "$USE_FIREWALL" = true ]; then
    DOCKER_ARGS+=(--cap-add=NET_ADMIN -e ENABLE_FIREWALL=1)
fi

# Temporarily disable exit on error for docker run so we can capture and
# propagate Claude's exit code instead of bailing out.
# `${arr[@]+"${arr[@]}"}` keeps an empty CLAUDE_ARGS safe under bash 3.2 + set -u.
set +e
docker run "${DOCKER_ARGS[@]}" "$CONTAINER_IMAGE" --dangerously-skip-permissions --model 'claude-opus-4-6[1m]' ${CLAUDE_ARGS[@]+"${CLAUDE_ARGS[@]}"}
CONTAINER_EXIT_CODE=$?
set -e

# Warn on non-zero exit code
if [ "$CONTAINER_EXIT_CODE" -ne 0 ]; then
    echo -e "${YELLOW}Warning: Container exited with code $CONTAINER_EXIT_CODE${NC}"
fi

# Restore .git file so worktree is a valid git repo again
restore_gitfile

# Check for changes in worktree
echo
WORKTREE_CHANGES=$(git -C "$WORKTREE_DIR" status --porcelain 2>/dev/null || true)
if [ -z "$WORKTREE_CHANGES" ]; then
    echo -e "${GREEN}No changes were made${NC}"
    # Clean up worktree since nothing changed
    git -C "$PROJECT_DIR" worktree remove "$WORKTREE_DIR" 2>/dev/null || true
    git -C "$PROJECT_DIR" branch -d "$BRANCH_NAME" 2>/dev/null || true
    WORKTREE_DIR=""
    enter_worktree
    exit "$CONTAINER_EXIT_CODE"
fi

echo -e "${GREEN}Changes in worktree:${NC}"
git -C "$WORKTREE_DIR" status --short
echo
echo -e "${GREEN}Worktree: $WORKTREE_DIR${NC}"
echo -e "${GREEN}Branch: $BRANCH_NAME${NC}"

enter_worktree
exit "$CONTAINER_EXIT_CODE"
