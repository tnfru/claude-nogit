#!/bin/bash

# claude-nogit - Run Claude Code in a safe container without git access
# Usage: claude-nogit [options] [project-directory] [-- claude-args...]

set -e

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

# Parse arguments
FULL_COPY=false
INTERACTIVE=false
SHOW_DIFF=false
FORCE_REBUILD=false
USE_FIREWALL=true
PURGE_SESSIONS=false
DOCKER_NETWORK=""
PROJECT_DIR=""
CLAUDE_ARGS=()

while [[ $# -gt 0 ]]; do
    case $1 in
        --full)
            FULL_COPY=true
            shift
            ;;
        --interactive)
            INTERACTIVE=true
            shift
            ;;
        --show-diff)
            SHOW_DIFF=true
            shift
            ;;
        --rebuild)
            FORCE_REBUILD=true
            shift
            ;;
        --firewall)
            USE_FIREWALL=true
            shift
            ;;
        --no-firewall)
            USE_FIREWALL=false
            shift
            ;;
        --network)
            DOCKER_NETWORK="$2"
            shift 2
            ;;
        --purge-sessions)
            PURGE_SESSIONS=true
            shift
            ;;
        -h|--help)
            echo "claude-nogit - Run Claude Code in a safe container without git access"
            echo "Usage: claude-nogit [options] [project-directory] [-- claude-args...]"
            echo ""
            echo "Options:"
            echo "  --full             Include node_modules/.venv (slower but complete)"
            echo "  --interactive      Prompt before copying changes back"
            echo "  --show-diff        Show diff review before auto-copying"
            echo "  --rebuild          Force Docker image rebuild"
            echo "  --firewall         Enable network firewall (default; only allows Anthropic, GitHub, npm)"
            echo "  --no-firewall      Disable network firewall (unrestricted network access)"
            echo "  --network NAME     Connect container to a Docker network (e.g. for databases)"
            echo "  --purge-sessions   Delete all session data for the given project and exit"
            echo "  -h, --help         Show help"
            echo ""
            echo "Arguments after -- are passed directly to Claude:"
            echo "  claude-nogit /path/to/project -- --model opus --resume"
            echo ""
            echo "By default excludes .git and large dependency dirs for speed."
            echo "Respects .gitignore for additional exclusions."
            echo "Changes are automatically copied back unless --interactive is used."
            exit 0
            ;;
        --)
            shift
            CLAUDE_ARGS=("$@")
            break
            ;;
        *)
            PROJECT_DIR="$1"
            shift
            ;;
    esac
done

# Configuration
PROJECT_DIR="${PROJECT_DIR:-.}"
PROJECT_DIR="$(cd "$PROJECT_DIR" && pwd)"  # Convert to absolute path

# Handle --purge-sessions
if [ "$PURGE_SESSIONS" = true ]; then
    HOST_PROJECT_NAME=$(echo "$PROJECT_DIR" | sed 's|/|-|g')
    SESSION_DIR="$HOME/.claude/projects/$HOST_PROJECT_NAME"
    if [ -d "$SESSION_DIR" ]; then
        rm -rf "$SESSION_DIR"
        echo -e "${GREEN}✓ Purged session data for $PROJECT_DIR${NC}"
    else
        echo -e "${YELLOW}No session data found for $PROJECT_DIR${NC}"
    fi
    exit 0
fi

SAFE_WORKSPACE=$(mktemp -d /tmp/claude-workspace-XXXXXXXXXX)
# mktemp creates with 0700 permissions, keeping project files private
CONTAINER_IMAGE="claude-code-dev"

# Resolve devcontainer directory: prefer repo-local, fall back to ~/.claude/devcontainer
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -f "$SCRIPT_DIR/devcontainer/Dockerfile" ]; then
    DEVCONTAINER_DIR="$SCRIPT_DIR/devcontainer"
elif [ -f "$HOME/.claude/devcontainer/Dockerfile" ]; then
    DEVCONTAINER_DIR="$HOME/.claude/devcontainer"
else
    DEVCONTAINER_DIR=""
fi

# Validate project directory
if [ ! -d "$PROJECT_DIR" ]; then
    echo -e "${RED}Error: Directory '$PROJECT_DIR' does not exist${NC}"
    exit 1
fi

# Track whether project files have been synced back
PROJECT_SYNCED=false

# Generate unique container ID (PID + timestamp to avoid collisions)
CONTAINER_ID="$$-$(date +%s)"

# Cleanup function for proper signal handling
cleanup() {
    local exit_code=$?

    # If container is still running, stop it
    local cid
    cid=$(docker ps -q --filter "name=claude-safe-${CONTAINER_ID}" 2>/dev/null)
    if [ -n "$cid" ]; then
        echo -e "\n${YELLOW}Stopping container...${NC}"
        docker stop "claude-safe-${CONTAINER_ID}" >/dev/null 2>&1 || true
    fi

    # Sync Claude state back to host
    if [ -n "${ISOLATED_CLAUDE:-}" ] && [ -d "$ISOLATED_CLAUDE" ]; then
        # Map container's -workspace sessions back to the host's real project name
        if [ -d "$ISOLATED_CLAUDE/projects/${CONTAINER_PROJECT_NAME:-}" ] && [ "$(ls -A "$ISOLATED_CLAUDE/projects/$CONTAINER_PROJECT_NAME" 2>/dev/null)" ]; then
            echo -e "${YELLOW}Saving project sessions...${NC}"
            mkdir -p "$HOME/.claude/projects/$HOST_PROJECT_NAME"
            cp -a "$ISOLATED_CLAUDE/projects/$CONTAINER_PROJECT_NAME"/. "$HOME/.claude/projects/$HOST_PROJECT_NAME/" 2>/dev/null || true
        fi
        # Sync sessions
        if [ -d "$ISOLATED_CLAUDE/sessions" ] && [ "$(ls -A "$ISOLATED_CLAUDE/sessions" 2>/dev/null)" ]; then
            echo -e "${YELLOW}Saving sessions...${NC}"
            mkdir -p "$HOME/.claude/sessions"
            cp -a "$ISOLATED_CLAUDE/sessions"/. "$HOME/.claude/sessions/" 2>/dev/null || true
        fi
        # Sync todos
        if [ -d "$ISOLATED_CLAUDE/todos" ] && [ "$(ls -A "$ISOLATED_CLAUDE/todos" 2>/dev/null)" ]; then
            echo -e "${YELLOW}Saving todos...${NC}"
            mkdir -p "$HOME/.claude/todos"
            cp -a "$ISOLATED_CLAUDE/todos"/. "$HOME/.claude/todos/" 2>/dev/null || true
        fi
    fi

    # If project files weren't synced back yet, preserve the workspace for recovery
    if [ "$PROJECT_SYNCED" = false ] && [ -n "${SAFE_WORKSPACE:-}" ] && [ -d "$SAFE_WORKSPACE" ]; then
        echo -e "${YELLOW}Changes were not synced back to project.${NC}"
        echo -e "${YELLOW}Your workspace is preserved at: $SAFE_WORKSPACE${NC}"
        echo -e "${YELLOW}To recover, run:${NC}"
        echo -e "${YELLOW}  rsync -av --exclude='.git/' --exclude='.DS_Store' --exclude='.claude-isolated' '$SAFE_WORKSPACE/' '$PROJECT_DIR/'${NC}"
    else
        # Clean up temporary directories (including .claude-isolated inside it)
        if [ -n "${SAFE_WORKSPACE:-}" ] && [ -d "$SAFE_WORKSPACE" ]; then
            rm -rf "$SAFE_WORKSPACE" 2>/dev/null || true
        fi
    fi

    exit $exit_code
}

# Set up signal handlers
trap cleanup SIGINT SIGTERM EXIT

echo -e "${GREEN}=== Safe Claude Code Runner ===${NC}"
echo -e "Project: $PROJECT_DIR"
echo -e "Safe workspace: $SAFE_WORKSPACE"
echo

# Build exclusion list as arrays (no eval needed)
EXCLUDES=(--exclude='.git/')

if [ "$FULL_COPY" = false ]; then
    echo -e "${YELLOW}Fast mode: Excluding large dependency directories${NC}"
    EXCLUDES+=(--exclude='node_modules' --exclude='.venv' --exclude='__pycache__' --exclude='*.pyc')
else
    echo -e "${YELLOW}Full mode: Including all dependencies (may be slow)${NC}"
fi

# Respect .gitignore files (per-directory merge handles nested .gitignore correctly)
EXCLUDES+=(--filter=':- .gitignore')

# Create clean copy
echo -e "${YELLOW}Creating clean workspace...${NC}"
rsync -av "${EXCLUDES[@]}" --exclude='.DS_Store' "$PROJECT_DIR/" "$SAFE_WORKSPACE/"

# Create isolated .claude directory for this project
ISOLATED_CLAUDE="$SAFE_WORKSPACE/.claude-isolated"
mkdir -p "$ISOLATED_CLAUDE"

# Copy necessary config files into isolated directory
for file in .credentials.json settings.json CLAUDE.md; do
    if [ -f "$HOME/.claude/$file" ]; then
        cp "$HOME/.claude/$file" "$ISOLATED_CLAUDE/"
    fi
done
# Copy hook scripts so settings.json hook commands (e.g. ~/.claude/fix-resume.sh) work inside the container
for script in "$HOME/.claude/"*.sh; do
    [ -f "$script" ] && cp "$script" "$ISOLATED_CLAUDE/"
done
for dir in devcontainer hooks agents skills plugins statsig; do
    if [ -d "$HOME/.claude/$dir" ]; then
        cp -a "$HOME/.claude/$dir" "$ISOLATED_CLAUDE/"
    fi
done

# Project name mapping:
# Host uses the real path (e.g. -home-lars-code-myproject)
# Container sees /workspace, so Claude stores sessions under -workspace
HOST_PROJECT_NAME=$(echo "$PROJECT_DIR" | sed 's|/|-|g')
CONTAINER_PROJECT_NAME="-workspace"

echo -e "${YELLOW}Project session name: $HOST_PROJECT_NAME${NC}"
mkdir -p "$ISOLATED_CLAUDE/projects/$CONTAINER_PROJECT_NAME"
mkdir -p "$ISOLATED_CLAUDE/todos"
mkdir -p "$ISOLATED_CLAUDE/shell-snapshots"
mkdir -p "$ISOLATED_CLAUDE/sessions"

# Copy existing project sessions into the container's expected path
if [ -d "$HOME/.claude/projects/$HOST_PROJECT_NAME" ] && [ "$(ls -A "$HOME/.claude/projects/$HOST_PROJECT_NAME" 2>/dev/null)" ]; then
    echo -e "${YELLOW}Loading existing project sessions...${NC}"
    cp -a "$HOME/.claude/projects/$HOST_PROJECT_NAME"/. "$ISOLATED_CLAUDE/projects/$CONTAINER_PROJECT_NAME/"
else
    echo -e "${YELLOW}No existing sessions found for this project${NC}"
fi

# Copy existing sessions if they exist
if [ -d "$HOME/.claude/sessions" ] && [ "$(ls -A "$HOME/.claude/sessions" 2>/dev/null)" ]; then
    cp -a "$HOME/.claude/sessions"/. "$ISOLATED_CLAUDE/sessions/"
fi

# Copy existing todos if they exist
if [ -d "$HOME/.claude/todos" ] && [ "$(ls -A "$HOME/.claude/todos" 2>/dev/null)" ]; then
    cp -a "$HOME/.claude/todos"/. "$ISOLATED_CLAUDE/todos/"
fi

echo -e "${GREEN}✓ Created isolated Claude configuration${NC}"
echo -e "${GREEN}✓ Project-specific session storage enabled${NC}"

# Detect host Claude version for image version matching
HOST_CLAUDE_VERSION=$(claude --version 2>/dev/null | grep -oP '[\d.]+' | head -1)
if [ -z "$HOST_CLAUDE_VERSION" ]; then
    echo -e "${YELLOW}Could not detect host Claude version, using image default${NC}"
    HOST_CLAUDE_VERSION=""
fi

# Check if container image needs building/rebuilding
NEEDS_BUILD=false
if ! docker image inspect "$CONTAINER_IMAGE" >/dev/null 2>&1; then
    NEEDS_BUILD=true
elif [ "$FORCE_REBUILD" = true ]; then
    echo -e "${YELLOW}Forced rebuild requested${NC}"
    NEEDS_BUILD=true
elif [ -n "$HOST_CLAUDE_VERSION" ]; then
    CURRENT_IMAGE_VERSION=$(docker image inspect "$CONTAINER_IMAGE" --format '{{index .Config.Labels "claude.version"}}' 2>/dev/null || echo "")
    if [ "$CURRENT_IMAGE_VERSION" != "$HOST_CLAUDE_VERSION" ]; then
        echo -e "${YELLOW}Claude version mismatch: image=$CURRENT_IMAGE_VERSION host=$HOST_CLAUDE_VERSION${NC}"
        NEEDS_BUILD=true
    fi
fi

if [ "$NEEDS_BUILD" = true ]; then
    if [ -n "$DEVCONTAINER_DIR" ]; then
        echo -e "${YELLOW}Building Claude Code container${HOST_CLAUDE_VERSION:+ (v$HOST_CLAUDE_VERSION)}...${NC}"
        BUILD_ARGS=()
        if [ "$FORCE_REBUILD" = true ]; then
            BUILD_ARGS+=(--no-cache)
        fi
        if [ -n "$HOST_CLAUDE_VERSION" ]; then
            BUILD_ARGS+=(--build-arg "CLAUDE_CODE_VERSION=$HOST_CLAUDE_VERSION")
        fi
        docker build -t "$CONTAINER_IMAGE" "${BUILD_ARGS[@]}" "$DEVCONTAINER_DIR/"
    else
        echo -e "${RED}Error: Cannot find Dockerfile. Run from the claude-nogit repo or place Dockerfile at ~/.claude/devcontainer/Dockerfile${NC}"
        exit 1
    fi
fi

# Run container
echo -e "${GREEN}Starting Claude container...${NC}"
echo -e "${YELLOW}You're now in a safe environment. The .git folder is not accessible.${NC}"
echo -e "${GREEN}Claude will auto-start with --dangerously-skip-permissions${NC}"
if [ "$USE_FIREWALL" = true ]; then
    echo -e "${GREEN}Network firewall enabled (only Anthropic, GitHub, npm allowed)${NC}"
else
    echo -e "${RED}Warning: Firewall disabled (--no-firewall). Claude has unrestricted network access.${NC}"
fi
echo

# Build docker run arguments
DOCKER_ARGS=(
    -it --rm
    --name "claude-safe-${CONTAINER_ID}"
    -v "$SAFE_WORKSPACE:/workspace"
    -v "$ISOLATED_CLAUDE:/home/node/.claude"
    --tmpfs /tmp:rw,exec,size=100m
    --sysctl net.ipv6.conf.all.disable_ipv6=1
    -e TZ="${TZ:-$(cat /etc/timezone 2>/dev/null || echo UTC)}"
    -w /workspace
)

if [ -f "$HOME/.claude.json" ]; then
    DOCKER_ARGS+=(-v "$HOME/.claude.json:/home/node/.claude.json")
fi

if [ -n "$DOCKER_NETWORK" ]; then
    DOCKER_ARGS+=(--network "$DOCKER_NETWORK")
fi

if [ "$USE_FIREWALL" = true ]; then
    DOCKER_ARGS+=(--cap-add=NET_ADMIN -e ENABLE_FIREWALL=1)
    DOCKER_ARGS+=(--entrypoint /usr/local/bin/entrypoint.sh)
else
    DOCKER_ARGS+=(--entrypoint claude)
fi

# Temporarily disable exit on error for docker run
set +e
docker run "${DOCKER_ARGS[@]}" "$CONTAINER_IMAGE" --dangerously-skip-permissions "${CLAUDE_ARGS[@]}"
CONTAINER_EXIT_CODE=$?
set -e

# Warn on non-zero exit code
if [ "$CONTAINER_EXIT_CODE" -ne 0 ]; then
    echo -e "${YELLOW}Warning: Container exited with code $CONTAINER_EXIT_CODE${NC}"
    echo -e "${YELLOW}Files may be in an inconsistent state. Review changes carefully.${NC}"
fi

# After container exits, check for changes
echo
echo -e "${YELLOW}=== Reviewing Changes ===${NC}"

# Build sync exclusions (used for both change detection and sync-back)
SYNC_EXCLUDES=(--exclude='.git/' --exclude='.DS_Store' --exclude='.claude-isolated')
if [ "$FULL_COPY" = false ]; then
    SYNC_EXCLUDES+=(--exclude='node_modules' --exclude='.venv' --exclude='__pycache__' --exclude='*.pyc')
fi
# Per-directory .gitignore merge filter handles nested .gitignore correctly
SYNC_EXCLUDES+=(--filter=':- .gitignore')

# Check if there are any changes using rsync dry-run (same filters as sync-back for consistency)
CHANGE_OUTPUT=$(rsync -avn --delete "${SYNC_EXCLUDES[@]}" "$SAFE_WORKSPACE/" "$PROJECT_DIR/" 2>/dev/null \
    | grep -v -E '^(sending|sent |total size|\./$|$)' || true)
if [ -z "$CHANGE_OUTPUT" ]; then
    echo -e "${GREEN}No changes were made${NC}"
    PROJECT_SYNCED=true
    exit 0
fi

# Show changes
echo "Changes:"
echo "$CHANGE_OUTPUT"
echo "(Lines starting with 'deleting' indicate files removed by Claude)"

if [[ "$SHOW_DIFF" = true ]] || [[ "$INTERACTIVE" = true ]]; then
    echo
    echo -e "${YELLOW}Review detailed diff? (y/n)${NC}"
    read -p "> " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        diff -ur --exclude='.git' --exclude='.DS_Store' --exclude='.claude-isolated' "$PROJECT_DIR" "$SAFE_WORKSPACE" || true
    fi
fi

if [[ "$INTERACTIVE" = true ]]; then
    echo
    echo -e "${GREEN}Copy changes back to project? (y/n)${NC}"
    read -p "> " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        rsync -av --delete "${SYNC_EXCLUDES[@]}" "$SAFE_WORKSPACE/" "$PROJECT_DIR/"
        PROJECT_SYNCED=true
        echo -e "${GREEN}✓ Changes applied to project (including deletions)${NC}"
    else
        echo -e "${YELLOW}Changes not applied to project${NC}"
        echo -e "${YELLOW}Workspace preserved at: $SAFE_WORKSPACE${NC}"
        exit 1
    fi
else
    echo
    echo -e "${GREEN}Automatically copying changes back to project...${NC}"
    rsync -av --delete "${SYNC_EXCLUDES[@]}" "$SAFE_WORKSPACE/" "$PROJECT_DIR/"
    PROJECT_SYNCED=true
    echo -e "${GREEN}✓ Changes applied to project (including deletions)${NC}"
fi
